# Redis (same as GeminiBApiServer)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=changeme

# Celery
CELERY_BROKER_URL=redis://:changeme@redis:6379/0
CELERY_RESULT_BACKEND=redis://:changeme@redis:6379/1

# TTS defaults
DEFAULT_GENERATOR=silero
DEFAULT_SPEAKER=eugene
DEFAULT_SAMPLE_RATE=48000

# Temp dir for generated audio files
TEMP_DIR=temp
